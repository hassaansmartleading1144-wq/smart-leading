# Ignore everything in the project root by default
/*

# Keep this file
!.gitignore

# Keep wp-content with selected subdirectories
!wp-content/
wp-content/*
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/smart-leading-net/
!wp-content/themes/smart-leading-net/**
!wp-content/plugins/
!wp-content/plugins/**
!wp-content/uploads/
!wp-content/uploads/**

# WordPress core (explicit exclusions for clarity)
/wp-admin/
/wp-includes/
/wp-config.php
/wp-config-sample.php
/wp-content/cache/
/wp-content/upgrade/
/wp-content/backup*/
/wp-content/backups/
/wp-content/advanced-cache.php
/wp-content/object-cache.php
/wp-content/db.php

# Database dumps and backups
*.sql
*.sql.gz
*.sqlite
*.bak
*.backup

# Logs and debug output
*.log
debug.log
error_log

# Cache and temporary files
**/cache/
**/Cache/
*.cache
*.tmp
*.temp
/tmp/
/temp/

# OS and editor files
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Dependency / build artifacts
node_modules/
vendor/
*.zip
*.tar
*.tar.gz

# Environment and secrets
.env
.env.*
!.env.example
